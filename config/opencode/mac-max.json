  "provider": {
    "ollama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (this Mac — unverified tier)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder-next:80b": {
          "name": "Qwen3-Coder-Next 80B MoE (unverified)",
